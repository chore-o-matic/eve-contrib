# Credentials for the opt-in e2e test (`npm run test:e2e`).
# Copy to .env.local (gitignored) and fill in. From the Meta App dashboard -> WhatsApp.

# Required: the e2e suite authenticates these against the real Graph API.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Optional: Graph API version (defaults to v21.0).
# WHATSAPP_API_VERSION=v21.0

# Optional: set to an E.164 number to ACTUALLY send a test message to it.
# The recipient must be within the 24-hour customer-service window (i.e. they
# messaged your business number recently), otherwise the send fails with Meta's
# re-engagement error. Leave empty to run only the read-only auth check.
# WHATSAPP_E2E_RECIPIENT=+15551234567
